{
  "name": "masumi-identity-sdk-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20",
    "pnpm": "10.x"
  },
  "scripts": {
    "build": "pnpm --filter \"@masumi_network/identity-sdk\" build",
    "build:all": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm --filter \"@masumi_network/identity-sdk\" test",
    "test:integration": "pnpm --filter \"@masumi_network/identity-sdk\" test:integration",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "typecheck": "pnpm build && pnpm -r typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.11",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "prettier": "3.7.3",
    "typescript": "5.7.3",
    "typescript-eslint": "8.48.0"
  }
}
